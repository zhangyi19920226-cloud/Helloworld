import numpy as np
import matplotlib.pyplot as plt

x = np.linspace(-2, 3, 100)
y1 = 2**x
y2 = (1/2)**x

plt.plot(x, y1, label='y=2^x')
plt.plot(x, y2, label='y=(1/2)^x')
plt.axhline(0, color='black', linewidth=0.5)
plt.axvline(0, color='black', linewidth=0.5)
plt.legend()
plt.grid(True)
plt.title('指数函数图像')
plt.show()
